# Server
NODE_ENV=development
PORT=5001
API_BASE_URL=http://localhost:5001
CLIENT_URL=http://localhost:5173

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/isazi_visitor_portal

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_EXPIRES_IN=8h
JWT_COOKIE_EXPIRES_DAYS=1

# Seed Admin (used by npm run seed:admin)
SEED_ADMIN_NAME=Super Admin
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=Admin@123
SEED_ADMIN_MOBILE=9999999999

# Rate limiting
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX_REQUESTS=300
PUBLIC_RATE_LIMIT_WINDOW_MINUTES=15
PUBLIC_RATE_LIMIT_MAX_REQUESTS=60

# QR / Public Visitor Portal
VISITOR_PORTAL_PUBLIC_URL=http://localhost:5173/visitor
QR_DEFAULT_LOCATION=Reception

# Company Defaults (used to seed system_settings)
COMPANY_NAME=ISAZI Pharma and Techno Consultancy Pvt. Ltd.
COMPANY_ADDRESS=604, Dream Rise, Science City Road, Near Hetarth Party Plot, Sola, Ahmedabad - 380060, Gujarat, India.
COMPANY_EMAIL=contact@isazi.biz
COMPANY_WEBSITE=www.isazi.biz
COMPANY_PHONE=+91 95742 75666

# Visitor ID format
VISITOR_ID_PREFIX=VIS
VISITOR_ID_YEAR_IN_ID=true

# Auto-close cron (24h HH:mm, server local time)
AUTO_CLOSE_CRON_EXPRESSION=0 0 * * *

# File uploads
UPLOAD_DIR=src/uploads
MAX_UPLOAD_SIZE_MB=5

# Logging
LOG_LEVEL=info
